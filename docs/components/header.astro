---
import GithubLineIcon from '../icons/github-line.astro'
import ThemeToggle from './theme-toggle.astro'
import Logo from './logo.astro'
---

<header class="header">
  <a href="/" class="home-link" aria-label="Perfectionist home page">
    <Logo class="logo" />
    <span>Perfectionist</span>
  </a>
  <nav class="nav">
    <a href="#" class="nav-link">Guide</a>
    <a href="#" class="nav-link">Configs</a>
    <a href="#" class="nav-link">Rules</a>
    <hr class="hr" />
    <ThemeToggle class="nav-link" />
    <hr class="hr" />
    <a
      class="nav-link"
      href="https://github.com/azat-io/eslint-plugin-perfectionist"
      target="_blank"
    >
      <GithubLineIcon class="icon" />
    </a>
  </nav>
</header>

<style>
  .home-link {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 12px;
    font-weight: 700;
    color: inherit;
    text-decoration: none;
    border-radius: 9999px;
    outline: none;
    transition: background 200ms ease-in-out;
  }

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 8px;
    padding-inline: 32px;
    color: var(--color-content-primary);
    background: var(--color-background-primary);
  }

  .logo {
    inline-size: 48px;
    block-size: 48px;
    padding: 2px;
  }

  .nav {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .nav-link {
    display: flex;
    padding: 0;
    padding: 12px;
    color: inherit;
    text-decoration: none;
    background: transparent;
    border: 0;
    border-radius: 9999px;
    outline: none;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .home-link:focus-visible {
    background: var(--color-background-secondary);
  }

  .hr {
    inline-size: 1px;
    block-size: 28px;
    margin-block: 4px;
    background: var(--color-background-secondary);
    border: none;
  }

  .icon {
    inline-size: 28px;
    block-size: 28px;
  }
</style>
